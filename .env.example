# =============================================
# Polkadot Validator Monitor — configuration
# =============================================

# Validator stash address (SS58)
VALIDATOR_ADDRESS=1FRMM8PEiWXYax7rpS6X4XZX1aAAxSWx1CrKTyrVYhV2ngU

# Telegram bot credentials
TELEGRAM_BOT_TOKEN=123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890

# Asset Hub RPC — staking, nominators, payouts (post-AHM November 2025)
RPC_ENDPOINT=wss://polkadot-asset-hub-rpc.polkadot.io

# Relay Chain RPC — session keys only
RC_RPC_ENDPOINT=wss://rpc.polkadot.io

# Network name shown in notifications
NETWORK=polkadot

# LevelDB state directory
DB_PATH=./data/state.db

# Heartbeat interval in ms — node is considered offline after 2× this value without a new block
HEARTBEAT_INTERVAL=60000

# Minimum pause between same-type alerts (ms) — prevents notification flooding
NOTIFICATION_COOLDOWN=300000

# Active nominator check interval (ms) — uses erasStakers, fast
NOM_CHECK_INTERVAL=300000

# Session key check interval (ms)
KEY_CHECK_INTERVAL=300000

# Waiting nominator scan interval (ms) — heavy full-chain scan, keep infrequent
PENDING_CHECK_INTERVAL=14400000

# Oversubscribed alert threshold — nominators beyond this limit receive no rewards
OVERSUB_LIMIT=512

# Consecutive missed heartbeats before offline alert fires (default 3 = ~3 min)
OFFLINE_THRESHOLD=3

# Consecutive blocks received before online alert fires (default 2)
ONLINE_THRESHOLD=2
